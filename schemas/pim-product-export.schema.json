{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voxster.ch/schemas/pim-product-export.json",
  "title": "PimPam Product Export",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "pimpam_product_id": { "type": "string", "minLength": 1 },
          "medusa_product_id": { "type": ["string", "null"] },
          "handle": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "subtitle": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["draft", "published", "proposed", "rejected"]
          },
          "external_id": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
          "product_type": { "type": ["string", "null"] },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "pimpam_category_id": { "type": ["string", "null"] },
                "medusa_category_id": { "type": ["string", "null"] }
              }
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "images": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          },
          "downloads": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": { "type": ["string", "null"] },
                "language": { "type": ["string", "null"] },
                "url": { "type": "string", "format": "uri" }
              },
              "required": ["url"]
            }
          },
          "attributes": {
            "type": ["object", "null"],
            "additionalProperties": true
          },
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "pimpam_variant_id": { "type": "string", "minLength": 1 },
                "medusa_variant_id": { "type": ["string", "null"] },
                "sku": { "type": "string", "minLength": 1 },
                "ean": { "type": ["string", "null"] },
                "barcode": { "type": ["string", "null"] },
                "title": { "type": ["string", "null"] },
                "manage_inventory": { "type": ["boolean", "null"] },
                "allow_backorder": { "type": ["boolean", "null"] },
                "prices": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "currency_code": { "type": "string", "minLength": 3 },
                      "amount": { "type": "number" }
                    },
                    "required": ["currency_code", "amount"]
                  }
                },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "name": { "type": "string", "minLength": 1 },
                      "value": { "type": "string", "minLength": 1 }
                    },
                    "required": ["name", "value"]
                  }
                }
              },
              "required": ["pimpam_variant_id", "sku", "prices"]
            }
          },
          "metadata": {
            "type": ["object", "null"],
            "additionalProperties": true
          }
        },
        "required": [
          "pimpam_product_id",
          "handle",
          "title",
          "status",
          "variants"
        ]
      }
    }
  },
  "required": ["products"]
}
